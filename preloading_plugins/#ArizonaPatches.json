{
	
	// Remove the effects from the game
	"UseCustomRenderEffects": false,
	"CustomRenderEffects": 63,

	// Enable camera correction in the interior
	"CCamInteriorFix": true,
	
	// Enable correction of the map center
	"COcclusionFix": true,
	
	// Disable the forced installation of window mode
	"DontDefaultWindowMode": true,
	
	// Remove memory changes that interfere with anti-afk operation
	"DontInterfereAntiAFK": false,
	
	// Remove green areas that prevent the use of weapons
	"DontUseGreenZone": true,
	
	// Remove the implementation of the enlarged radar icons
	"DontUseScaleRadarMapIcons": true,
	
	// Use the original feature of setting objects for the player/transport
	"DontUseCustomAttachObject": true,
	
	// Use standard chat and 3d text
	"DontUseCustomChat": false,
	
	// Use standard car rendering
	"DontUseCustomCarRender": true,
	
	// Use the original SAMP sync
	"DontUseCustomSync": true,
	
	// Delete memory changes for fastconnect operation
	"DontUseCustomFastConnect": false,
	
	// Use standard shadows
	"DontUseCustomShadow": true,
	
	// Do not use voice chat
	"DontUseVoiceChat": false,
	
	// Do not use ambient sounds
	"DontUseSoundSystem": true,
	
	// Do not draw 3d icons
	"DontUseCustomMarker": true,
	
	// Do not license plates
	"DontUseCustomNumberPlate": true,
	
	// Do not use screen dimming
	"DontUseFadeScreen": true,
	
	// Do not use a first-person camera
	"DontUseFirstPerson": true,
	
	// Use standard headlight light
	"DontUseCustomVehicleLightsColor": true,
	
	// Do not press the W key on the bike
	"DontPressWOnBike": true,
	
	// Launcher Object Drawing Settings
	"CustomObjectScaleDistance": 80.0,
	"CustomObjectMinimumDistance": 95.0,
	"CustomObjectMaximumDistance": 125.0,
	"CustomObjectForceDistance": false,
